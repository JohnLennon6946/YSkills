# =============================================
# Plurk MCP Server — 认证配置
# 复制此文件为 .env 并填写对应值
# =============================================

# 认证模式：oauth（推荐）或 password
PLURK_AUTH_MODE=oauth

# ----- OAuth 1.0a 模式 -----
# 前往 https://www.plurk.com/API/OAuth 申请 App 后填写
PLURK_APP_KEY=
PLURK_APP_SECRET=
PLURK_ACCESS_TOKEN=
PLURK_ACCESS_TOKEN_SECRET=

# ----- 账号密码模拟登录模式 -----
# 仅在 PLURK_AUTH_MODE=password 时使用
PLURK_USERNAME=
PLURK_PASSWORD=
